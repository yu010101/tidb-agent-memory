# TiDB Cloud Starter の接続情報 (★リージョンは ap-southeast-1 / Singapore で作成)
# ダッシュボード > Connect > "General" の値から組み立てる。TiDB Cloud は TLS 必須。
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=xxxxxxxx.root
TIDB_PASSWORD=
TIDB_DB=test

# 埋め込みバックエンド: local (APIキー不要) | openai
EMBED_BACKEND=local
# local: intfloat/multilingual-e5-small = 384 次元 (schema の VECTOR(384) と一致)
# openai: text-embedding-3-small = 1536 次元 → schema を VECTOR(1536) に変更すること
EMBED_DIM=384

# OpenAI を使う場合のみ
# OPENAI_API_KEY=
